# Copy this file to .env and fill in your actual values.
# Never commit .env to source control — it is in .gitignore.

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_development
DB_USER=
DB_PASSWORD=

# External API (obtain from the developer portal)
API_KEY=
API_BASE_URL=https://api.example.com/v1

# Application settings
SECRET_KEY=
APP_ENV=development
PORT=3000
LOG_LEVEL=info

# Feature flags
ENABLE_CACHE=true
CACHE_TTL=3600

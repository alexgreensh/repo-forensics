      "severity": "critical",
      "confidence": 0.97,
      "category": "private-key",
      "attacker": "anyone with repo access",
      "boundary": "source repository",
      "asset": "asymmetric private key",
      "explanation": "PEM private-key header committed in plaintext.",
      "examples": {
        "match": [
          "-----BEGIN RSA PRIVATE KEY-----",
          "-----BEGIN OPENSSH PRIVATE KEY-----",
          "-----BEGIN EC PRIVATE KEY-----",
          "-----BEGIN PRIVATE KEY-----"
        ],
        "no_match": [
          "-----BEGIN CERTIFICATE-----",
          "# generate a private key with openssl"
        ]
      }
    },
